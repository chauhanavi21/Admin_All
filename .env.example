# Local API (Render sets PORT automatically — do not override there)
PORT=4000

# Auth — use a long random secret in production (Render generates one via render.yaml)
JWT_SECRET=generate-a-long-random-secret
JWT_EXPIRES=7d

# Default admin seeded on first API start when store is empty
ADMIN_EMAIL=admin@agency.local
ADMIN_PASSWORD=admin123

# Frontend — baked into the Vite build (set on Vercel only)
VITE_API_URL=http://localhost:4000/api

# Backend CORS — set on Render after Vercel deploy
CLIENT_ORIGIN=http://localhost:5180

# Optional: extra allowed origins, comma-separated (e.g. Vercel preview URLs)
# CORS_ORIGINS=https://my-admin.vercel.app,https://my-admin-git-main.vercel.app

# Allow all *.vercel.app preview deployments (recommended for staging)
ALLOW_VERCEL_PREVIEWS=true
